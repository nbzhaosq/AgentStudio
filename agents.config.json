{
  "agents": [
    {
      "id": "claude",
      "name": "Claude",
      "color": "#d97706",
      "cmd": "claude",
      "args": ["-p", "{prompt}", "--permission-mode", "acceptEdits"]
    },
    {
      "id": "codex",
      "name": "Codex",
      "color": "#10b981",
      "cmd": "codex",
      "args": [
        "exec",
        "{prompt}",
        "--sandbox",
        "workspace-write",
        "--skip-git-repo-check",
        "-o",
        "{outfile}"
      ]
    },
    {
      "id": "kimi",
      "name": "Kimi",
      "color": "#3b82f6",
      "cmd": "kimi",
      "args": ["-p", "{prompt}"]
    },
    {
      "id": "qoder",
      "name": "Qoder",
      "color": "#f43f5e",
      "cmd": "qodercli",
      "args": ["-p", "--permission-mode", "auto", "{prompt}"]
    },
    {
      "id": "opencode",
      "name": "OpenCode",
      "color": "#14b8a6",
      "cmd": "opencode",
      "args": ["run", "{prompt}"]
    },
    {
      "id": "omp",
      "name": "OhMyPi",
      "color": "#84cc16",
      "cmd": "omp",
      "args": ["-p", "{prompt}"]
    },
    {
      "id": "pi",
      "name": "Pi",
      "color": "#6366f1",
      "cmd": "pi",
      "args": ["-p", "{prompt}"]
    },
    {
      "id": "openclaw",
      "name": "OpenClaw",
      "color": "#f97316",
      "cmd": "openclaw",
      "args": ["agent", "--message", "{prompt}", "--local"]
    },
    {
      "id": "hermes",
      "name": "Hermes",
      "color": "#0ea5e9",
      "cmd": "hermes",
      "args": ["chat", "-q", "{prompt}", "-Q", "--yolo"]
    },
    {
      "id": "mock-a",
      "name": "MockA",
      "color": "#a855f7",
      "cmd": "node",
      "args": ["{serverRoot}/scripts/mock-agent.mjs", "mock-a", "mock-b", "{prompt}"],
      "instructions": "演示用 mock agent（不调用模型）"
    },
    {
      "id": "mock-b",
      "name": "MockB",
      "color": "#ec4899",
      "cmd": "node",
      "args": ["{serverRoot}/scripts/mock-agent.mjs", "mock-b", "mock-a", "{prompt}"]
    }
  ]
}
